---
import Section from "@/components/Section.astro"
const { lang = 'es' } = Astro.props;

// Diccionario de etiquetas dinámicas con terminología académica internacional
const i18n = {
  es: {
    advisor: "Director/a",
    coAdvisor: "Co-Director/a",
    funding: "Financiamiento"
  },
  en: {
    advisor: "Project Director",
    coAdvisor: "Co-director",
    funding: "Funding"
  }
};

// Cargamos el archivo correspondiente mediante importación dinámica segura
const projectsModule = await import(`../../../data/${lang}/projects.json`);
const projects = projectsModule.default;
---

<Section>
  <div class="projects-container">
    {projects.map((project) => (
      <article class="project-item">
        <header>
          <div class="title-row">
            <h3>{project.title}</h3>
            <time>{project.period}</time>
          </div>
          
          <div class="subtitle-row">
            <span class={`institution-badge ${project.institution.toLowerCase().includes('conicet') ? 'conicet' : 'university'}`}>
              {project.institution}
            </span>
            <span class="resolution">{project.resolution}</span>
          </div>
        </header>

        <div class="details">
          <p>
            <strong>{i18n[lang].advisor}:</strong> {project.director}
            {project.coDirector && <span> | <strong>{i18n[lang].coAdvisor}:</strong> {project.coDirector}</span>}
          </p>
          <p class="id-amount">
            <span>ID: {project.id}</span>
            <span class="separator">•</span>
            <span>{i18n[lang].funding}: {project.amount}</span>
          </p>
        </div>
      </article>
    ))}
  </div>
</Section>

<style>
  .projects-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .title-row h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #111;
    line-height: 1.3;
    margin: 0;
    max-width: 80%;
  }

  .title-row time {
    font-size: 0.85rem;
    color: #666;
    font-family: ui-monospace, monospace;
    white-space: nowrap;
  }

  .subtitle-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    flex-wrap: wrap;
  }

  .institution-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  /* Colores institucionales */
  .conicet { background: #003366; color: white; }
  .university { background: #e5e7eb; color: #374151; }

  .resolution {
    font-size: 0.75rem;
    color: #666;
    font-style: italic;
  }

  .details {
    font-size: 0.9rem;
    color: #444;
    line-height: 1.4;
  }

  .id-amount {
    font-size: 0.8rem;
    color: #888;
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .separator {
    color: #ccc;
  }

  @media (max-width: 700px) {
    .title-row {
      flex-direction: column;
      gap: 0.3rem;
    }
    .title-row h3 {
      max-width: 100%;
    }
  }
</style>